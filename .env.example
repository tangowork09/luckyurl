# ── Data source ─────────────────────────────────────────────────────────────
# LeadScout picks a source by which of these is set, in this order:
#   GOOGLE_MAPS_API_KEY > APIFY_TOKEN > DEMO > (nothing = free OpenStreetMap)

# Google Maps Platform API key with "Places API (New)" enabled.
# Get one: https://console.cloud.google.com/ -> APIs & Services -> Credentials.
# Free tier ~5,000 calls/mo; billing card required on the project.
GOOGLE_MAPS_API_KEY=

# Apify token — paid Google-Maps scraper path (no Google billing card).
# Costs your Apify credits per run; scraping ToS/liability is on your account.
APIFY_TOKEN=
# Actor to run (default shown). Any Google-Maps-places actor with a compatible
# input works.
APIFY_ACTOR_ID=compass/crawler-google-places

# Force demo mode (deterministic fake data) when no key is set: DEMO=1
DEMO=

# ── Optional ─────────────────────────────────────────────────────────────────
# PageSpeed Insights API key (only needed for --psi at volume; keyless works
# at a few requests/minute).
PAGESPEED_API_KEY=

# Override scoring weights as JSON (deep-merged onto defaults). Example:
# SCORING_WEIGHTS={"base":{"broken-website":80},"chainPenalty":40}
SCORING_WEIGHTS=

# Web UI port (default 4600)
PORT=4600

# ── Auth + sessions ─────────────────────────────────────────────────────────
# HMAC secret for signed session cookies. REQUIRED in production
# (NODE_ENV=production). In dev, a random per-boot secret is used if unset
# (which logs everyone out on restart). Generate one:  openssl rand -hex 32
SESSION_SECRET=

# Public base URL of the deployment. Used for the Cashfree return_url and to
# decide whether cookies get the Secure flag (set automatically when https).
# Default: http://localhost:PORT
APP_BASE_URL=

# Seed admin account, created on first boot only if no admin exists yet AND
# ADMIN_PASSWORD is set. Change the password after first login.
ADMIN_EMAIL=admin@leadscout.local
ADMIN_PASSWORD=

# Directory for auth/billing JSON stores (users, plans, subscriptions, orders).
# Default ./data — mount a persistent volume here in production.
DATA_DIR=./data

# ── Cashfree Payment Gateway (upgrades / subscriptions) ─────────────────────
# Leave blank to run without paid plans (everyone stays on the free plan).
# Dashboard: https://merchant.cashfree.com/  (API version 2023-08-01)
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
# 'sandbox' (default) or 'production'
CASHFREE_ENV=sandbox
# Webhook signing secret. Defaults to CASHFREE_SECRET_KEY (Cashfree signs
# webhooks with the secret key), so you normally leave this blank.
CASHFREE_WEBHOOK_SECRET=

# Set to 'production' on your live host so SESSION_SECRET is enforced and
# secure defaults apply.
NODE_ENV=
